<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BeVerified — Choisissez votre offre</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#F2EEE8;--ink:#16120E;--ink3:#7A6F65;--ink4:#A89F96;--a1:#E8412A;--a2:#F5A623;--a4:#1EC8A0;--grad:linear-gradient(135deg,#E8412A,#F5A623)}
body{background:var(--bg);color:var(--ink);font-family:'Playfair Display',serif;min-height:100vh}

nav{background:rgba(242,238,232,0.95);backdrop-filter:blur(16px);border-bottom:1px solid rgba(22,18,14,0.08);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{text-decoration:none;display:flex;align-items:center;gap:8px}
.nav-back{font-size:13px;color:var(--ink3);text-decoration:none;display:flex;align-items:center;gap:6px;transition:color .2s}
.nav-back:hover{color:var(--ink)}

.hero{text-align:center;padding:64px 48px 48px;max-width:700px;margin:0 auto}
.step-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(22,18,14,0.06);color:var(--ink3);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:6px 14px;border-radius:100px;margin-bottom:20px}
.hero h1{font-size:clamp(28px,3.5vw,42px);font-weight:900;line-height:1.1;margin-bottom:12px}
.hero h1 em{font-style:normal;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero p{font-size:15px;color:var(--ink3);line-height:1.7;max-width:480px;margin:0 auto}

.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto;padding:0 24px 80px}

.card{background:white;border-radius:20px;padding:36px;border:2px solid rgba(22,18,14,0.06);position:relative;transition:all .25s;cursor:pointer}
.card:hover{border-color:rgba(22,18,14,0.15);transform:translateY(-4px);box-shadow:0 16px 48px rgba(22,18,14,0.1)}
.card.popular{border-color:var(--a1);box-shadow:0 8px 32px rgba(232,65,42,0.12)}

.popular-pill{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--grad);color:white;font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 16px;border-radius:100px;white-space:nowrap}

.card-name{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink4);margin-bottom:12px}
.card-price{font-size:48px;font-weight:900;line-height:1;margin-bottom:4px;color:var(--ink)}
.card-price span{font-size:16px;font-weight:400;color:var(--ink4)}
.card-monthly{font-size:13px;color:var(--ink3);margin-bottom:6px;min-height:20px}
.card-save{display:inline-block;background:rgba(30,200,160,0.1);color:var(--a4);font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;margin-bottom:20px}
.card-divider{height:1px;background:rgba(22,18,14,0.06);margin-bottom:20px}
.card-features{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:28px}
.card-features li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--ink3);line-height:1.4}
.card-features li::before{content:'✓';color:var(--a4);font-weight:700;flex-shrink:0;font-size:12px}

.card-btn{display:block;width:100%;padding:14px;border-radius:100px;font-family:'Playfair Display',serif;font-size:14px;font-weight:700;text-align:center;text-decoration:none;transition:all .2s;border:none;cursor:pointer}
.card-btn-default{background:var(--ink);color:white}
.card-btn-default:hover{background:#2D2520;transform:translateY(-1px)}
.card-btn-popular{background:var(--grad);color:white;box-shadow:0 4px 16px rgba(232,65,42,0.3)}
.card-btn-popular:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(232,65,42,0.35)}

.guarantee{text-align:center;padding:0 24px 64px;max-width:600px;margin:0 auto}
.guarantee-box{background:white;border-radius:16px;padding:24px;border:1px solid rgba(22,18,14,0.06)}
.guarantee-title{font-size:14px;font-weight:700;margin-bottom:8px;display:flex;align-items:center;justify-content:center;gap:8px}
.guarantee-desc{font-size:13px;color:var(--ink3);line-height:1.6}

.faq{max-width:700px;margin:0 auto;padding:0 24px 80px}
.faq-title{font-size:20px;font-weight:700;margin-bottom:24px;text-align:center}
.faq-item{border-bottom:1px solid rgba(22,18,14,0.08);padding:16px 0}
.faq-q{font-size:14px;font-weight:700;margin-bottom:6px}
.faq-a{font-size:13px;color:var(--ink3);line-height:1.6}

@media(max-width:768px){
  nav{padding:0 20px}
  .hero{padding:48px 20px 32px}
  .cards{grid-template-columns:1fr;padding:0 20px 60px}
  .card.popular{order:-1}
}
</style>
</head>
